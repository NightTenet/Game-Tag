<Window x:Class="Game_Tag_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Game_Tag_WPF"
        mc:Ignorable="d"
        Title="Game Tag" Height="500" Width="900" ResizeMode="CanMinimize" FontFamily="Consolas" >
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundColor" Color="#425523" />
        <SolidColorBrush x:Key="BoardColor" Color="#4a2e15" />
        <SolidColorBrush x:Key="TextColor" Color="#fefae0" />
        <SolidColorBrush x:Key="TileColor" Color="#bc6c25" />
        <SolidColorBrush x:Key="HoverTileColor" Color="#dda15e" />
        <SolidColorBrush x:Key="ButtonColor" Color="#283618" />
        <SolidColorBrush x:Key="HoverButtonColor" Color="#606c38" />
        <SolidColorBrush x:Key="ButtonBorderColor" Color="#dda15e" />

        <Style x:Key="TileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TileColor}" />
            <Setter Property="Foreground" Value="{StaticResource TextColor}" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{StaticResource HoverTileColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonColor}" />
            <Setter Property="Foreground" Value="{StaticResource TextColor}" />

            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderColor}" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{StaticResource HoverButtonColor}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundColor}" >
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BoardColor}" BorderThickness="2"
                BorderBrush="{StaticResource TextColor}" Width="400" Height="400" Margin="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    
                    <Button x:Name="Btn00" Grid.Row="0" Grid.Column="0" Content="1" FontSize="40" Margin="1,1,1,1" 
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn01" Grid.Row="0" Grid.Column="1" Content="2" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn02" Grid.Row="0" Grid.Column="2" Content="3" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn03" Grid.Row="0" Grid.Column="3" Content="4" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />

                    <Button x:Name="Btn10" Grid.Row="1" Grid.Column="0" Content="5" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn11" Grid.Row="1" Grid.Column="1" Content="6" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn12" Grid.Row="1" Grid.Column="2" Content="7" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn13" Grid.Row="1" Grid.Column="3" Content="8" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    
                    <Button x:Name="Btn20" Grid.Row="2" Grid.Column="0" Content="9" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn21" Grid.Row="2" Grid.Column="1" Content="10" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn22" Grid.Row="2" Grid.Column="2" Content="11" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn23" Grid.Row="2" Grid.Column="3" Content="12" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />

                    <Button x:Name="Btn30" Grid.Row="3" Grid.Column="0" Content="13" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn31" Grid.Row="3" Grid.Column="1" Content="14" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn32" Grid.Row="3" Grid.Column="2" Content="15" FontSize="40" Margin="1,1,1,1"
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" />
                    <Button x:Name="Btn33" Grid.Row="3" Grid.Column="3" Content="0" FontSize="40" Margin="1,1,1,1" 
                        Style="{StaticResource TileStyle}" IsEnabled="false" Click="Tile_Click" Visibility="Hidden" />
                </Grid>
            </Border>

            <TextBlock Text="Menu" Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0"
                FontSize="54" Foreground="{StaticResource TextColor}" />

            <TextBlock x:Name="MovesCount" Text="Moves: 0" Grid.Column="1" VerticalAlignment="Top" FontSize="26"
                Margin="20,100,0,0" Foreground="{StaticResource TextColor}" />

            <TextBlock x:Name="TimeCounter" Text="Time: 00:00" Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right" FontSize="26"
                Margin="0,100,20,0" Foreground="{StaticResource TextColor}" />
            
            <Button x:Name="StartGameButton" Content="Start Game" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Style="{StaticResource ButtonStyle}" FontSize="26" Width="180" Height="60" Margin="20,0,0,120"
                Click="StartGame_ButtonClick" />

            <Button x:Name="SolveGameButton" Content="Solve Game" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Style="{StaticResource ButtonStyle}" FontSize="26" Width="180" Height="60" Margin="0,0,20,120"
                IsEnabled="false" Click="SolveGame_ButtonClick" />

            <TextBlock x:Name="Message" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                FontSize="30" Foreground="{StaticResource TextColor}" />
            
            <Button x:Name="RulesButton" Content="Rules" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom"
            Style="{StaticResource ButtonStyle}" FontSize="26" Width="180" Height="60" Margin="0,0,0,50"
            Click="Rules_ButtonClick" IsEnabled="true" />
                
        </Grid>
    </Grid>
</Window>
